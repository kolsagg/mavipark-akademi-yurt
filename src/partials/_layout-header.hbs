<!DOCTYPE html>
<html lang="tr">
  <head>
    {{> _head-meta pageTitle=pageTitle siteDescription=(or siteDescription "Akademi Suit - Ayrıcalıklı Öğrenci Yurdu") }}

    <!-- Shared Preconnects -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://images.unsplash.com" />
    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
    <link rel="dns-prefetch" href="https://fonts.gstatic.com" />
    <link rel="dns-prefetch" href="https://images.unsplash.com" />

    <!-- Google Fonts -->
    <link
      href="https://fonts.googleapis.com/css2?family=Epilogue:wght@600;700;800&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
      media="print" 
      onload="this.media='all'"
    />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Epilogue:wght@600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    </noscript>

    <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />
    
    <!-- Critical CSS for Preloader & FOUC Prevention -->
    <style>
      #preloader {
        position: fixed;
        top: 0; left: 0;
        width: 100%; height: 100%;
        background: #FFFFFF; /* matches site background */
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 1;
        visibility: visible;
      }
      #app {
        opacity: 0;
      }
      /* Ensure app becomes visible when preloader starts exiting */
      body.app-ready #app {
        opacity: 1;
        transition: opacity 0.5s ease;
      }
    </style>
    <script>
      // Force immediate preloader display even before CSS load
      document.documentElement.classList.add('js-loading');
    </script>
    <noscript>
      <style>
        #app { opacity: 1 !important; }
        #preloader { display: none !important; }
        [data-reveal], [data-reveal-batch] { opacity: 1 !important; visibility: visible !important; }
      </style>
    </noscript>
