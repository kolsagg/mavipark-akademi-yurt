<section class="hero" data-theme-section="hero">
  <div class="hero__container">
    <div class="hero__content">
      <div class="hero__badge">
        <span class="material-symbols-outlined" aria-hidden="true">star</span>
        <span data-hero-badge>Premium Residence</span>
      </div>
      
      <h1 class="hero__title">
        <span data-hero-title-main>Modern & Konforlu</span>
        <span class="text-accent" data-hero-title-accent>Yaşam Alanı</span>
      </h1>
      
      <p class="hero__description" data-hero-desc>
        Akademi Suit, öğrenci hayatını en üst düzeye taşımak için tasarlanmış konforlu yaşam alanı sunar. Modern olanaklar, güvenli çevre ve merkezi konumla huzurlu bir yaşam.
      </p>
      
      <div class="hero__actions">
        <a href="#rooms" class="btn-cta btn-cta--primary">ODALARI KEŞFET</a>
        <a href="#amenities" class="btn-cta btn-cta--outline">İMKANLARI GÖR</a>
      </div>

      <div class="hero__highlight glass-card">
        <div class="hero__highlight-icon">
          <span class="material-symbols-outlined">verified_user</span>
        </div>
        <div class="hero__highlight-text">
          <h3 data-hero-highlight-title>Güvenli & Huzurlu</h3>
          <p data-hero-highlight-desc>7/24 güvenlik ve biyometrik geçiş sistemleri ile içiniz rahat olsun.</p>
        </div>
      </div>
    </div>

    <div class="hero__visual">
      <div class="hero__image-wrapper">
        <img src="" alt="Yurt Odası Görseli" class="hero__image" data-hero-img fetchpriority="high">
      </div>
    </div>
  </div>
</section>
