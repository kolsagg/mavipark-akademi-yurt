+++ b/src/components/Navigation.js
@@ -0,0 +1,121 @@
+import gsap from 'gsap';
+import ThemeManager from '../core/ThemeManager.js';
+
+/**
+ * Navigation Component
+ * Handles the theme switcher and header interactions.
+ */
+class Navigation {
+  static init() {
+    this.buttons = document.querySelectorAll('.js-nav-btn');
+    this.pill = document.querySelector('.js-nav-pill');
+    this.header = document.querySelector('.header');
+
+    // Create GSAP context for easy cleanup
+    this.ctx = gsap.context(() => {
+      this.initEvents();
+      this.initScroll();
+      
+      // Initial sync with current theme
+      const currentTheme = document.body.dataset.theme;
+      if (currentTheme) {
+        this.updatePill(currentTheme, false);
+      } else {
+        // If no theme, hide pill
+        if (this.pill) gsap.set(this.pill, { opacity: 0 });
+      }
+    });
+  }
+
+  /**
+   * Initializes event listeners for buttons and theme changes
+   */
+  static initEvents() {
+    this.menuToggle = document.querySelector('.js-menu-toggle');
+    this.nav = document.querySelector('.nav');
+
+    if (this.menuToggle && this.nav) {
+      this.menuToggle.addEventListener('click', () => {
+        this.nav.classList.toggle('nav--visible');
+      });
+    }
+
+    this.buttons.forEach(btn => {
+      btn.addEventListener('click', () => {
+        const targetTheme = btn.dataset.themeTarget;
+        ThemeManager.setTheme(targetTheme);
+      });
+    });
+
+    // Listen for theme changes from anywhere (ThemeManager, SplitHero, etc.)
+    window.addEventListener('themeChanged', (e) => {
+      const { theme } = e.detail;
+      this.updatePill(theme);
+    });
+  }
+
+  /**
+   * Handles header appearance on scroll
+   */
+  static initScroll() {
+    if (!this.header) return;
+
+    const handleScroll = () => {
+      if (window.scrollY > 50) {
+        this.header.classList.add('header--scrolled');
+      } else {
+        this.header.classList.remove('header--scrolled');
+      }
+    };
+
+    window.addEventListener('scroll', handleScroll, { passive: true });
+  }
+
+  /**
+   * Updates the switcher pill position and active state
+   * @param {string|null} theme - 'girls' or 'boys' or null
+   * @param {boolean} animate - whether to animate the transition
+   */
+  static updatePill(theme, animate = true) {
+    if (!this.pill || !this.buttons.length) return;
+
+    const targetBtn = Array.from(this.buttons).find(btn => btn.dataset.themeTarget === theme);
+    
+    // Reset aria-pressed for all buttons
+    this.buttons.forEach(btn => btn.setAttribute('aria-pressed', 'false'));
+
+    if (!targetBtn || !theme) {
+      gsap.to(this.pill, { 
+        opacity: 0, 
+        duration: animate ? 0.3 : 0,
+        ease: 'power2.inOut'
+      });
+      return;
+    }
+
+    // Set active button
+    targetBtn.setAttribute('aria-pressed', 'true');
+    
+    const { offsetLeft, offsetWidth } = targetBtn;
+
+    // Animate pill to target button position
+    gsap.to(this.pill, {
+      left: offsetLeft,
+      width: offsetWidth,
+      opacity: 1,
+      duration: animate ? 0.5 : 0,
+      ease: 'elastic.out(1, 0.8)' // Premium bouncy feel
+    });
+  }
+
+  /**
+   * Cleans up GSAP context and listeners
+   */
+  static cleanup() {
+    if (this.ctx) {
+      this.ctx.revert();
+    }
+  }
+}
+
+export default Navigation;
diff --git a/src/core/ThemeManager.js b/src/core/ThemeManager.js
new file mode 100644
index 0000000..040e30a
--- /dev/null
+++ b/src/core/ThemeManager.js
@@ -0,0 +1,82 @@
+class ThemeManager {
+  /**
+   * Initializes the ThemeManager
+   */
+  static init() {
+    // Read theme from URL on load
+    const theme = this.getThemeFromURL();
+    this.applyTheme(theme); // Apply even if null to ensure clean state
+
+    // Listen for history changes
+    window.addEventListener('popstate', () => {
+      const newTheme = this.getThemeFromURL();
+      this.applyTheme(newTheme, false); // false to avoid recursive pushState
+    });
+  }
+
+  /**
+   * Reads theme from URL search params or path
+   * @returns {string|null} 'girls' or 'boys' or null
+   */
+  static getThemeFromURL() {
+    const params = new URLSearchParams(window.location.search);
+    const type = params.get('type')?.toLowerCase();
+    
+    if (type === 'girls' || type === 'boys') {
+      return type;
+    }
+
+    // Fallback to pathname (check segments for precision)
+    const pathSegments = window.location.pathname.toLowerCase().split('/');
+    if (pathSegments.includes('kiz')) return 'girls';
+    if (pathSegments.includes('erkek')) return 'boys';
+
+    return null;
+  }
+
+  /**
+   * Applies the theme to the body and dispatches event
+   * @param {string|null} theme - 'girls' or 'boys' or null
+   * @param {boolean} [updateHistory=true] - whether to update URL history
+   */
+  static applyTheme(theme, updateHistory = true) {
+    // If theme is null, we can either clear it or keep default. 
+    // Requirements say URL-First, so we clear if URL has no preference.
+    if (theme && theme !== 'girls' && theme !== 'boys') return;
+
+    if (theme) {
+      document.body.dataset.theme = theme;
+      if (updateHistory) this.updateURL(theme);
+    } else {
+      delete document.body.dataset.theme;
+    }
+
+    // Dispatch CustomEvent regardless of choice to let subscribers sync
+    const event = new CustomEvent('themeChanged', { detail: { theme } });
+    window.dispatchEvent(event);
+  }
+
+  /**
+   * Updates the URL search params without reloading the page
+   * @param {string} theme - 'girls' or 'boys'
+   */
+  static updateURL(theme) {
+    if (theme !== 'girls' && theme !== 'boys') return;
+
+    const url = new URL(window.location.href || 'http://localhost');
+    url.searchParams.set('type', theme);
+    
+    // We only want the path and search for pushState
+    const newUrl = url.pathname + url.search;
+    window.history.pushState({}, '', newUrl);
+  }
+
+  /**
+   * Convenience method to set theme externally
+   */
+  static setTheme(theme) {
+    this.applyTheme(theme, true);
+  }
+}
+
+export default ThemeManager;
