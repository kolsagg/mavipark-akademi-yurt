diff --git a/src/styles/components/_navigation.css b/src/styles/components/_navigation.css
new file mode 100644
index 0000000..2f3e9f2
--- /dev/null
+++ b/src/styles/components/_navigation.css
@@ -0,0 +1,199 @@
+/**
+ * Navigation Component Styles
+ * Header, Logo, and Theme Switcher
+ */
+
+.header {
+  position: fixed;
+  top: 0;
+  left: 0;
+  width: 100%;
+  z-index: var(--z-nav);
+  padding: var(--space-4) 0;
+  transition: background var(--transition-base), padding var(--transition-base), border var(--transition-base);
+  backdrop-filter: blur(var(--blur-glass-light));
+  background: var(--color-glass-white);
+  border-bottom: 1px solid rgba(var(--color-white-rgb), 0.1);
+}
+
+.header--scrolled {
+  padding: var(--space-2) 0;
+  background: var(--color-glass-white);
+  box-shadow: var(--shadow-sm);
+}
+
+.header__container {
+  max-width: 1440px;
+  margin: 0 auto;
+  padding: 0 var(--space-6);
+  display: flex;
+  justify-content: space-between;
+  align-items: center;
+}
+
+/* Logo */
+.logo {
+  display: flex;
+  flex-direction: column;
+  text-decoration: none;
+  color: var(--theme-text);
+  transition: color var(--transition-base);
+}
+
+.logo__text {
+  font-family: var(--font-heading);
+  font-size: var(--font-size-xl);
+  font-weight: var(--font-weight-bold);
+  letter-spacing: var(--letter-spacing-tight);
+  line-height: 1;
+}
+
+.logo__sub {
+  font-size: var(--font-size-xs);
+  font-weight: var(--font-weight-medium);
+  letter-spacing: 0.2em;
+  color: var(--theme-primary);
+  margin-top: 2px;
+  transition: color var(--transition-base);
+}
+
+/* Navigation Switcher */
+.nav__switcher {
+  position: relative;
+  display: flex;
+  background: rgba(0, 0, 0, 0.05);
+  padding: 4px;
+  border-radius: var(--radius-full);
+  gap: 4px;
+  border: 1px solid rgba(255, 255, 255, 0.2);
+  backdrop-filter: blur(5px);
+}
+
+.nav__switcher-pill {
+  position: absolute;
+  top: 4px;
+  left: 4px;
+  height: calc(100% - 8px);
+  width: calc(50% - 6px);
+  background: var(--theme-primary);
+  border-radius: var(--radius-full);
+  z-index: 1;
+  box-shadow: var(--shadow-sm);
+  pointer-events: none;
+  transition: background var(--transition-base);
+}
+
+.nav__switcher-btn {
+  position: relative;
+  z-index: 2;
+  padding: var(--space-2) var(--space-5);
+  border: none;
+  background: transparent;
+  font-family: var(--font-body);
+  font-size: var(--font-size-sm);
+  font-weight: var(--font-weight-semibold);
+  color: var(--theme-text);
+  cursor: pointer;
+  border-radius: var(--radius-full);
+  transition: color var(--transition-fast);
+  min-width: 90px;
+}
+
+.nav__switcher-btn[aria-pressed="true"] {
+  color: var(--color-white);
+}
+
+/* Button CTA */
+.btn-cta {
+  display: inline-block;
+  padding: var(--space-2) var(--space-5);
+  background: var(--theme-accent);
+  color: var(--color-white);
+  text-decoration: none;
+  font-weight: var(--font-weight-bold);
+  font-size: var(--font-size-sm);
+  border-radius: var(--radius-full);
+  transition: transform var(--transition-fast), box-shadow var(--transition-fast), background var(--transition-base);
+  box-shadow: var(--shadow-md);
+  border: none;
+}
+
+.btn-cta:hover {
+  transform: translateY(-2px);
+  box-shadow: var(--shadow-lg);
+  color: var(--color-white);
+}
+
+/* Mobile Menu Toggle */
+.header__menu-toggle {
+  display: none;
+  flex-direction: column;
+  justify-content: center;
+  align-items: center;
+  gap: 6px;
+  background: rgba(0, 0, 0, 0.05);
+  border: none;
+  cursor: pointer;
+  width: 44px;
+  height: 44px;
+  border-radius: var(--radius-md);
+  transition: background var(--transition-fast);
+}
+
+.header__menu-toggle span {
+  display: block;
+  width: 24px;
+  height: 2px;
+  background: var(--theme-text);
+  transition: transform var(--transition-base), opacity var(--transition-base);
+}
+
+/* Responsive */
+@media (max-width: 1024px) {
+  .header__container {
+    padding: 0 var(--space-4);
+  }
+}
+
+@media (max-width: 768px) {
+  .header {
+    padding: var(--space-3) 0;
+  }
+
+  .header__actions .btn-cta {
+    display: none;
+  }
+  
+  .header__menu-toggle {
+    display: flex;
+  }
+  
+  .nav {
+    position: absolute;
+    top: 100%;
+    left: 0;
+    width: 100%;
+    background: var(--color-glass-white);
+    backdrop-filter: blur(var(--blur-glass));
+    padding: var(--space-4);
+    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
+    display: none; /* Controlled by JS later, or keep visible for now if no menu logic */
+    justify-content: center;
+  }
+
+  /* For now, let's keep the switcher visible on mobile header if possible, or just below logo */
+  .nav--visible {
+    display: flex;
+  }
+  
+  .nav__switcher {
+    width: 100%;
+    max-width: 280px;
+  }
+
+  .nav__switcher-btn {
+    height: 44px;
+    flex: 1;
+    min-width: 0;
+  }
+}
