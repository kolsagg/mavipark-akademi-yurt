+  destroy() {
+    if (this.ctx) {
+      this.ctx.revert();
+      this.ctx = null;
+    }
+  }
+
+  /**
+   * Renders room cards based on the current theme
+   */
+  renderRooms() {
+    if (!this.container) return;
+
+    const themeKey = this.currentTheme === 'boys' ? 'erkek' : 'kiz';
