+          </ul>
+        </div>
+        <div class="glass-card__footer">
+          <span class="room-type-badge room-type-badge--outline">${room.type}</span>
+          <button class="room-panel__btn" aria-label="Keşfet: ${room.title}">KEŞFET</button>
+        </div>
+      </div>
+    `;
+  }
